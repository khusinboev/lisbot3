# Telegram Bot Token
# Get from @BotFather: https://t.me/BotFather
BOT_TOKEN=your_bot_token_here

# Admin User IDs (comma-separated)
# Get your ID from @userinfobot: https://t.me/userinfobot
ADMIN_IDS=123456789,987654321

# ─── TELEGRAM BOT UI COLOR SCHEME (Telegram Bot API v7.7+) ─────────
# Bot tugmalari Telegram ning yangi color feature bilan ranglangan:
# 🔵 KO'K (BLUE) - Asosiy amallari uchun:
#    - "📥 Барча сертификатларни йиғиш"
#    - "📊 Статистика"
#    - "📄 PDF юклаш (саралганлар)"
# 🟢 YASHIL (GREEN) - Ijobiy amallari uchun:
#    - "✅ Ҳа" (tasdiq)
# 🔴 QIZIL (RED) - Manfiy/bekor qilish amallari uchun:
#    - "❌ Йўқ" (rad etish/bekor qilish)
#
# Ranglar Telegram v7.7+ Bot API tomonida avtomatik qo'llaniladi.
# aiogram 3.10+ bilan to'liq ishlaydi.
# ──────────────────────────────────────────────────────────────────

# Optional settings
DB_PATH=data/certificates.db
DOWNLOAD_DIR=downloads
TARGET_ACTIVITY_TYPE=Олий таълим хизматлари
SCRAPE_UPDATE_EVERY_PAGES=5
SCRAPE_START_PAGE=1
SCRAPE_CONTINUE_ON_PAGE_ERROR=true
SCRAPE_COOLDOWN_EVERY_PAGES=10
SCRAPE_COOLDOWN_SECONDS=6
UPDATE_PROGRESS_EVERY_ITEMS=10
DOWNLOAD_PROGRESS_EVERY_ITEMS=5
UPDATE_ITEM_DELAY_SECONDS=0.35
DOWNLOAD_ITEM_DELAY_SECONDS=0.5

# Auto-check (har 5 soatda yangi sertifikatlarni tekshiradi)
AUTO_CHECK_ENABLED=true
AUTO_CHECK_INTERVAL_HOURS=5
AUTO_CHECK_MAX_PAGES=60
AUTO_CHECK_NOTIFY_EVERY_ITEMS=10

# Auto-update (har kuni Toshkent vaqti bilan 03:00)
AUTO_UPDATE_ENABLED=true
AUTO_UPDATE_TZ=Asia/Tashkent
AUTO_UPDATE_HOUR=3
AUTO_UPDATE_MINUTE=0
AUTO_UPDATE_MAX_PAGES=300
AUTO_UPDATE_PROGRESS_EVERY_PAGES=10

# Har bir item/notification orasidagi majburiy pauza
AUTO_REQUEST_ITEM_DELAY_SECONDS=1.0
AUTO_NOTIFY_DELAY_SECONDS=0.6

# Parser v2 startup behavior
# Dedicated profile dir for parser v2 (kept persistent between runs)
PARSER_V2_PROFILE_DIR=data/chrome_profile_parser_v2
# Optional shared profile override (used if PARSER_V2_PROFILE_DIR is not set)
CHROME_PROFILE_DIR=
# Headless mode control: true/false
CHROME_HEADLESS=false
# If true, skips YouTube warmup stage
SKIP_WARMUP=false
# If running in container, parser prefers headless by default
IN_DOCKER=false
