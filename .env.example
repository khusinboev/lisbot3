# Telegram Bot Token
# Get from @BotFather: https://t.me/BotFather
BOT_TOKEN=your_bot_token_here

# Admin User IDs (comma-separated)
# Get your ID from @userinfobot: https://t.me/userinfobot
ADMIN_IDS=123456789,987654321

# Optional settings
DB_PATH=data/certificates.db
DOWNLOAD_DIR=downloads
TARGET_ACTIVITY_TYPE=Олий таълим хизматлари
SCRAPE_UPDATE_EVERY_PAGES=5
UPDATE_PROGRESS_EVERY_ITEMS=10
DOWNLOAD_PROGRESS_EVERY_ITEMS=5
UPDATE_ITEM_DELAY_SECONDS=0.35
DOWNLOAD_ITEM_DELAY_SECONDS=0.5

# Parser v2 startup behavior
# Dedicated profile dir for parser v2 (kept persistent between runs)
PARSER_V2_PROFILE_DIR=data/chrome_profile_parser_v2
# Optional shared profile override (used if PARSER_V2_PROFILE_DIR is not set)
CHROME_PROFILE_DIR=
# Headless mode control: true/false
CHROME_HEADLESS=false
# If true, skips YouTube warmup stage
SKIP_WARMUP=false
# If running in container, parser prefers headless by default
IN_DOCKER=false
